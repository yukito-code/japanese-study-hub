---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import PageBackLink from "../../components/PageBackLink.astro";
import { ui } from "../../i18n/ui";

const base = import.meta.env.BASE_URL;
---

<BaseLayout titleKey="title.kanjiList" descKey="meta.kanji.list">
  <SiteHeader showLevelBar={true} topHref={`${base}`} />
  <main>
    <h1 class="hero-title" data-ui="kanji.list.title">{ui.ja["kanji.list.title"]}</h1>
    <PageBackLink href={`${base}kanji/`} />

    <div id="kanji-list-root"></div>
  </main>

  <script type="application/json" id="kanji-list-config" set:html={JSON.stringify({ base })}></script>
  <script>
    import { mountKanjiListPage } from "../../scripts/kanji-list-page";
    mountKanjiListPage("kanji-list-config");
  </script>
</BaseLayout>
