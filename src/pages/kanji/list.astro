---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { ui } from "../../i18n/ui";

const base = import.meta.env.BASE_URL;
---

<BaseLayout titleKey="title.kanjiList" descKey="meta.kanji.list">
  <SiteHeader showLevelBar={true} backHref={`${base}kanji/`} backUiKey="nav.kanjiHub" />
  <main>
    <h1 class="hero-title" data-ui="kanji.list.title">{ui.ja["kanji.list.title"]}</h1>
    <p class="hero-lead">
      <span class="num-em" id="kanji-list-count">—</span><span data-ui="kanji.leadSuffix">{ui.ja["kanji.leadSuffix"]}</span>
    </p>

    <div id="kanji-list-root"></div>

    <p class="footer-note" data-ui="kanji.disclaimer">{ui.ja["kanji.disclaimer"]}</p>
  </main>

  <script type="application/json" id="kanji-list-config" set:html={JSON.stringify({ base })}></script>
  <script>
    import { mountKanjiListPage } from "../../scripts/kanji-list-page";
    mountKanjiListPage("kanji-list-config");
  </script>
</BaseLayout>
