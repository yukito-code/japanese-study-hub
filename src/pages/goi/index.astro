---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { ui, type UiKey } from "../../i18n/ui";

const base = import.meta.env.BASE_URL;

const cats = [
  {
    id: "kanji-yomi",
    href: `${base}goi/kanji-yomi/`,
    titleKey: "goi.card.kanji.title" as UiKey,
    descKey: "goi.card.kanji.desc" as UiKey,
  },
  {
    id: "bunmyaku",
    href: `${base}goi/bunmyaku/`,
    titleKey: "goi.card.bunmyaku.title" as UiKey,
    descKey: "goi.card.bunmyaku.desc" as UiKey,
  },
  {
    id: "iikae",
    href: `${base}goi/iikae/`,
    titleKey: "goi.card.iikae.title" as UiKey,
    descKey: "goi.card.iikae.desc" as UiKey,
  },
];
---

<BaseLayout titleKey="title.goiHub" descKey="meta.goi.description">
  <SiteHeader backHref={`${base}`} backUiKey="nav.top" />
  <main>
    <h1 class="hero-title" data-ui="goi.hub.title">{ui.ja["goi.hub.title"]}</h1>
    <p class="hero-lead" data-ui="goi.hub.lead">{ui.ja["goi.hub.lead"]}</p>

    <div class="goi-hub-grid">
      {
        cats.map((c) => (
          <a class="goi-hub-card" href={c.href}>
            <h3 data-ui={c.titleKey}>{ui.ja[c.titleKey]}</h3>
            <p data-ui={c.descKey}>{ui.ja[c.descKey]}</p>
          </a>
        ))
      }
    </div>

    <p class="footer-note" data-ui="goi.footer">{ui.ja["goi.footer"]}</p>
  </main>
</BaseLayout>
