---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import bank from "../../data/jlpt-questions.json";
import { ui, type UiKey } from "../../i18n/ui";

const base = import.meta.env.BASE_URL;

const TITLE_KEY: Record<string, UiKey> = {
  "kanji-yomi": "title.goiKanjiYomi",
  bunmyaku: "title.goiBunmyaku",
  iikae: "title.goiIikae",
};

const H1_KEY: Record<string, UiKey> = {
  "kanji-yomi": "goi.pageTitle.kanjiYomi",
  bunmyaku: "goi.pageTitle.bunmyaku",
  iikae: "goi.pageTitle.iikae",
};

const LEAD_KEY: Record<string, UiKey> = {
  "kanji-yomi": "goi.lead.kanjiYomi",
  bunmyaku: "goi.lead.bunmyaku",
  iikae: "goi.lead.iikae",
};

export function getStaticPaths() {
  return bank.categories.map((c) => ({ params: { category: c.id } }));
}

const id = Astro.params.category ?? "";
const cat = bank.categories.find((c) => c.id === id);
if (!cat || !TITLE_KEY[id]) {
  return Astro.redirect(`${import.meta.env.BASE_URL}goi/`);
}

const titleKey = TITLE_KEY[id];
const h1Key = H1_KEY[id];
const leadKey = LEAD_KEY[id];
---

<BaseLayout titleKey={titleKey} descKey="meta.goi.description">
  <SiteHeader backHref={`${base}goi/`} backUiKey="nav.goiHub" />
  <main>
    <h1 class="hero-title" data-ui={h1Key}>{ui.ja[h1Key]}</h1>
    <p class="hero-lead" data-ui={leadKey}>{ui.ja[leadKey]}</p>

    <p class="goi-prompt" id="goi-prompt">—</p>
    <p class="quiz-prompt" id="goi-instruction" data-ui="goi.instruction">
      {ui.ja["goi.instruction"]}
    </p>

    <p class="progress-text" id="goi-progress" aria-live="polite">—</p>

    <div class="card" style="margin-top: 0.65rem">
      <div class="quiz-options" id="goi-options"></div>
      <div id="goi-feedback" class="quiz-feedback" hidden>
        <p id="goi-feedback-head" style="margin: 0 0 0.35rem; font-weight: 700"></p>
        <p id="goi-correct-line" style="margin: 0 0 0.35rem"></p>
        <p class="goi-explain-title" data-ui="goi.explain.title">
          {ui.ja["goi.explain.title"]}
        </p>
        <p class="goi-explain-body" id="goi-explain-body"></p>
      </div>
      <div class="nav-row" style="margin-top: 1rem">
        <button type="button" class="btn btn-primary" id="goi-next" disabled data-ui="goi.next">
          {ui.ja["goi.next"]}
        </button>
      </div>
    </div>

    <p class="footer-note" data-ui="goi.footer">{ui.ja["goi.footer"]}</p>
  </main>

  <script type="application/json" id="goi-quiz-payload" set:html={JSON.stringify(cat)}></script>
  <script>
    import { mountGoiQuiz } from "../../scripts/goi-quiz-page";
    mountGoiQuiz();
  </script>
</BaseLayout>
