---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import PageBackLink from "../../components/PageBackLink.astro";
import bank from "../../data/jlpt-questions.json";
import { ui, type UiKey } from "../../i18n/ui";

const base = import.meta.env.BASE_URL;

const TITLE_KEY: Record<string, UiKey> = {
  "kanji-yomi": "title.goiKanjiYomi",
  bunmyaku: "title.goiBunmyaku",
  iikae: "title.goiIikae",
};

const PAGE_TITLE_KEY: Record<string, UiKey> = {
  "kanji-yomi": "goi.pageTitle.kanjiYomi",
  bunmyaku: "goi.pageTitle.bunmyaku",
  iikae: "goi.pageTitle.iikae",
};

export function getStaticPaths() {
  return bank.categories.map((c) => ({ params: { category: c.id } }));
}

const id = Astro.params.category ?? "";
const cat = bank.categories.find((c) => c.id === id);
if (!cat || !TITLE_KEY[id]) {
  return Astro.redirect(`${import.meta.env.BASE_URL}`);
}

const titleKey = TITLE_KEY[id];
const pageTitleKey = PAGE_TITLE_KEY[id];
---

<BaseLayout titleKey={titleKey} descKey="meta.goi.description">
  <SiteHeader topHref={`${base}`} />
  <main>
    <h1
      class="hero-title"
      data-ui={pageTitleKey}
      id="goi-page-heading"
      data-page-title-key={pageTitleKey}
    >
      {ui.ja[pageTitleKey]}
    </h1>
    <PageBackLink href={`${base}`} />

    <div id="goi-level-unavailable" class="card card-muted" hidden>
      <p data-ui="goi.levelUnavailable">{ui.ja["goi.levelUnavailable"]}</p>
    </div>

    <div id="goi-quiz-root">
      <p class="goi-prompt" id="goi-prompt">—</p>

      <p class="progress-text" id="goi-progress" aria-live="polite">—</p>

      <div class="card" style="margin-top: 0.65rem">
        <div class="quiz-options" id="goi-options"></div>
        <div class="nav-row nav-row--quiz-footer" style="margin-top: 1rem">
          <button
            type="button"
            class="btn btn-secondary"
            id="goi-prev"
            disabled
            data-ui="goi.prev"
          >
            {ui.ja["goi.prev"]}
          </button>
          <button type="button" class="btn btn-goi-next" id="goi-next" disabled data-ui="goi.next">
            {ui.ja["goi.next"]}
          </button>
        </div>
        <div id="goi-feedback" class="quiz-feedback" hidden>
          <p id="goi-feedback-head" style="margin: 0 0 0.35rem; font-weight: 700"></p>
          <p id="goi-correct-line" style="margin: 0 0 0.35rem"></p>
          <p class="goi-explain-title" data-ui="goi.explain.title">
            {ui.ja["goi.explain.title"]}
          </p>
          <p class="goi-explain-body" id="goi-explain-body"></p>
        </div>
      </div>
    </div>
  </main>

  <script type="application/json" id="goi-quiz-payload" set:html={JSON.stringify(cat)} />
  <script>
    import { mountGoiQuiz } from "../../scripts/goi-quiz-page";
    mountGoiQuiz();
  </script>
</BaseLayout>
