---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import PageBackLink from "../../../components/PageBackLink.astro";
import LearnBlocks from "../../../components/LearnBlocks.astro";
import { ui } from "../../../i18n/ui";
import {
  kaiwaAisatsuIntro,
  kaiwaAisatsuSections,
} from "../../../data/kaiwa-aisatsu";
import { kaiwaAisatsuQuizItems } from "../../../data/kaiwa-aisatsu-quiz";

const base = import.meta.env.BASE_URL;
const quizPayload = JSON.stringify({ items: kaiwaAisatsuQuizItems });
---

<BaseLayout titleKey="title.learnKaiwaAisatsu" descKey="meta.learn.kaiwaAisatsu">
  <SiteHeader />
  <main class="learn-article">
    <div id="kaiwa-page-back-wrap">
      <PageBackLink href={`${base}`} />
    </div>
    <h1 class="hero-title" data-ui="learn.kaiwa.aisatsu.h1">{ui.ja["learn.kaiwa.aisatsu.h1"]}</h1>

    <div id="kaiwa-read-panel">
      <div id="kaiwa-read-cta-wrap" class="kaiwa-action-row">
        <button
          type="button"
          class="btn btn-kaiwa-quiz-cta"
          id="kaiwa-btn-open-quiz"
          data-ui="learn.kaiwa.quiz.startButton">{ui.ja["learn.kaiwa.quiz.startButton"]}</button>
      </div>

      <div data-locale-block="ja">
        <p class="hero-lead learn-intro">{kaiwaAisatsuIntro.ja}</p>
      </div>
      <div data-locale-block="en">
        <p class="hero-lead learn-intro">{kaiwaAisatsuIntro.en}</p>
      </div>
      <div data-locale-block="zh">
        <p class="hero-lead learn-intro">{kaiwaAisatsuIntro.zh}</p>
      </div>

      {
        kaiwaAisatsuSections.map((sec) => (
          <section class="learn-section">
            <div data-locale-block="ja">
              <h2 class="hero-title hero-title--section">{sec.ja.title}</h2>
              <LearnBlocks blocks={sec.ja.blocks} />
            </div>
            <div data-locale-block="en">
              <h2 class="hero-title hero-title--section">{sec.en.title}</h2>
              <LearnBlocks blocks={sec.en.blocks} />
            </div>
            <div data-locale-block="zh">
              <h2 class="hero-title hero-title--section">{sec.zh.title}</h2>
              <LearnBlocks blocks={sec.zh.blocks} />
            </div>
          </section>
        ))
      }

      <p class="learn-foot card-muted" data-ui="learn.kaiwa.disclaimer">
        {ui.ja["learn.kaiwa.disclaimer"]}
      </p>
    </div>

    <div id="kaiwa-quiz-panel" class="kaiwa-quiz-panel" hidden>
      <PageBackLink id="kaiwa-btn-back-read" />

      <h2 class="hero-title hero-title--section" data-ui="learn.kaiwa.quiz.sectionTitle">
        {ui.ja["learn.kaiwa.quiz.sectionTitle"]}
      </h2>

      <p class="kaiwa-quiz-prompt" id="kaiwa-quiz-prompt" lang="ja"></p>
      <p class="progress-text" id="kaiwa-quiz-progress" aria-live="polite"></p>

      <div class="card" style="margin-top: 0.65rem">
        <div id="kaiwa-quiz-play">
          <div class="quiz-options" id="kaiwa-quiz-options"></div>
          <div class="nav-row nav-row--quiz-footer" style="margin-top: 1rem">
            <button
              type="button"
              class="btn btn-secondary"
              id="kaiwa-quiz-prev"
              disabled
              data-ui="learn.kaiwa.quiz.prevQuestion">{ui.ja["learn.kaiwa.quiz.prevQuestion"]}</button>
            <button type="button" class="btn btn-goi-next" id="kaiwa-quiz-next" disabled data-ui="learn.kaiwa.quiz.next">
              {ui.ja["learn.kaiwa.quiz.next"]}
            </button>
          </div>
          <div id="kaiwa-quiz-feedback" class="quiz-feedback" hidden>
            <p id="kaiwa-quiz-feedback-head" style="margin: 0 0 0.35rem; font-weight: 700"></p>
            <p id="kaiwa-quiz-correct-line" style="margin: 0 0 0.35rem" lang="ja"></p>
            <p class="goi-explain-title" data-ui="goi.explain.title">{ui.ja["goi.explain.title"]}</p>
            <p class="goi-explain-body" id="kaiwa-quiz-explain-body"></p>
          </div>
        </div>
        <div id="kaiwa-round-summary" class="quiz-round-summary" hidden>
          <p class="quiz-round-summary__title" data-ui="learn.kaiwa.quiz.roundSummary.title">
            {ui.ja["learn.kaiwa.quiz.roundSummary.title"]}
          </p>
          <p class="quiz-round-summary__pct" id="kaiwa-round-summary-pct" aria-live="polite"></p>
          <p class="quiz-round-summary__detail" id="kaiwa-round-summary-detail"></p>
          <button
            type="button"
            class="btn btn-goi-next quiz-round-summary__restart"
            id="kaiwa-round-restart"
            data-ui="learn.kaiwa.quiz.roundSummary.restart"
          >
            {ui.ja["learn.kaiwa.quiz.roundSummary.restart"]}
          </button>
        </div>
      </div>
    </div>
  </main>

  <script type="application/json" id="kaiwa-quiz-payload" set:html={quizPayload} />
  <script>
    import { mountKaiwaAisatsuPage } from "../../../scripts/kaiwa-aisatsu-page";
    mountKaiwaAisatsuPage();
  </script>
</BaseLayout>

<style>
  .kaiwa-action-row {
    margin: 0.35rem 0 1.1rem;
    display: flex;
    justify-content: center;
  }

  .kaiwa-quiz-panel {
    padding-bottom: 0.5rem;
  }

  .kaiwa-quiz-prompt {
    margin: 0.35rem 0 0.4rem;
    font-size: 1.12rem;
    line-height: 1.65;
    color: var(--color-ink-soft);
  }

  .nav-row--quiz-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .nav-row--quiz-footer .btn-goi-next {
    margin-left: auto;
  }

  @media (min-width: 56rem) {
    .kaiwa-quiz-prompt {
      font-size: 1.22rem;
    }
  }
</style>
