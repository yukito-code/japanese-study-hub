---
import "../styles/global.css";
import { fillTemplate, ui, type UiKey } from "../i18n/ui";

type Props = {
  /** クライアントで document.title を切り替えるときのキー */
  titleKey?: UiKey;
  /** `{ level: "N5" }` のように fillTemplate に渡す（多言語タイトル用） */
  titleTemplateKey?: UiKey;
  titleTemplateVars?: Record<string, string>;
  title?: string;
  descKey?: UiKey;
  description?: string;
};

const {
  titleKey,
  titleTemplateKey,
  titleTemplateVars,
  title = ui.ja["site.name"],
  descKey,
  description = ui.ja["meta.home.description"],
} = Astro.props;

let pageTitle = title;
if (titleTemplateKey && titleTemplateVars) {
  pageTitle = fillTemplate(ui.ja[titleTemplateKey], titleTemplateVars);
} else if (titleKey) {
  pageTitle = ui.ja[titleKey];
}

const pageDesc = descKey ? ui.ja[descKey] : description;
const base = import.meta.env.BASE_URL;

const bodyAttrs: Record<string, string> = {};
if (titleKey) bodyAttrs["data-title-key"] = titleKey;
if (titleTemplateKey) bodyAttrs["data-title-template-key"] = titleTemplateKey;
if (titleTemplateVars) bodyAttrs["data-title-template-vars"] = JSON.stringify(titleTemplateVars);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content={pageDesc}
      {...descKey ? { "data-desc-key": descKey } : {}}
    />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;600;700&family=Noto+Sans+SC:wght@400;600;700&family=Noto+Sans:wght@400;600&family=Noto+Serif+JP:wght@500;600&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
  </head>
  <body {...bodyAttrs}>
    <div class="page-shell">
      <div class="page-shell-inner" aria-hidden="true"></div>
      <div class="page-frame">
        <slot />
      </div>
    </div>
    <script>
      import { initI18n } from "../i18n/client";
      initI18n();
    </script>
  </body>
</html>
