---
import { ui } from "../i18n/ui";

type Props = {
  href: string;
};

const { href } = Astro.props;
---

<div class="site-title-banner">
  <div class="site-title-banner__vignette" aria-hidden="true"></div>
  <div class="site-title-banner__frame" aria-hidden="true"></div>

  <svg
    class="site-title-banner__decor site-title-banner__decor--tl"
    viewBox="0 0 96 58"
    aria-hidden="true"
    focusable="false"
  >
    <defs>
      <linearGradient id="kumo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#4a5d6e"></stop>
        <stop offset="100%" stop-color="#2e3d4a"></stop>
      </linearGradient>
    </defs>
    <rect x="2" y="6" width="58" height="11" rx="5.5" fill="url(#kumo-grad)" opacity="0.92"></rect>
    <rect x="14" y="22" width="64" height="11" rx="5.5" fill="url(#kumo-grad)"></rect>
    <rect x="6" y="38" width="50" height="11" rx="5.5" fill="url(#kumo-grad)" opacity="0.88"></rect>
  </svg>

  <svg
    class="site-title-banner__decor site-title-banner__decor--bl"
    viewBox="0 0 92 80"
    aria-hidden="true"
    focusable="false"
  >
    <defs>
      <linearGradient id="wave-fill" x1="0%" y1="100%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#b8a88c"></stop>
        <stop offset="100%" stop-color="#d4c4a8"></stop>
      </linearGradient>
    </defs>
    <path d="M0 80 A92 92 0 0 1 92 80 Z" fill="url(#wave-fill)"></path>
    <path
      d="M2 80 A90 90 0 0 1 90 80"
      fill="none"
      stroke="#fffaf2"
      stroke-width="2.2"
      opacity="0.9"></path>
    <path
      d="M10 80 A82 82 0 0 1 82 80"
      fill="none"
      stroke="#fffaf2"
      stroke-width="1.6"
      opacity="0.75"></path>
    <path
      d="M20 80 A72 72 0 0 1 72 80"
      fill="none"
      stroke="#fffaf2"
      stroke-width="1.2"
      opacity="0.55"></path>
    <path
      d="M32 80 A60 60 0 0 1 60 80"
      fill="none"
      stroke="#fffaf2"
      stroke-width="0.9"
      opacity="0.38"></path>
  </svg>

  <svg
    class="site-title-banner__decor site-title-banner__decor--tr"
    viewBox="0 0 96 96"
    aria-hidden="true"
    focusable="false"
  >
    <defs>
      <linearGradient id="asanoha-bg" x1="100%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" stop-color="#f0e6d4"></stop>
        <stop offset="100%" stop-color="#dcc9a8"></stop>
      </linearGradient>
    </defs>
    <path d="M96 0 A96 96 0 0 0 0 96 L96 96 Z" fill="url(#asanoha-bg)"></path>
    <g stroke="#8a6f2a" stroke-width="0.55" fill="none" opacity="0.5">
      <path d="M48 8 72 32 48 56 24 32Z"></path>
      <path d="M48 28 72 52 48 76 24 52Z"></path>
      <path d="M48 48 72 72 48 96 24 72Z"></path>
      <path d="M58 18 82 42 58 66 34 42Z"></path>
      <path d="M38 18 62 42 38 66 14 42Z"></path>
      <path d="M68 4 92 28 68 52 44 28Z"></path>
      <path d="M28 4 52 28 28 52 4 28Z"></path>
      <path d="M78 34 96 52 78 70 60 52Z"></path>
    </g>
  </svg>

  <svg
    class="site-title-banner__decor site-title-banner__decor--br"
    viewBox="0 0 108 96"
    aria-hidden="true"
    focusable="false"
  >
    <defs>
      <radialGradient id="tsubaki-core" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#fffdf8"></stop>
        <stop offset="100%" stop-color="#f5ebe0"></stop>
      </radialGradient>
      <linearGradient id="petal-grad" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#c4585c"></stop>
        <stop offset="100%" stop-color="#7a2328"></stop>
      </linearGradient>
    </defs>
    <ellipse cx="54" cy="50" rx="26" ry="22" fill="#a83a40" opacity="0.35"></ellipse>
    <ellipse cx="46" cy="40" rx="16" ry="15" fill="url(#petal-grad)"></ellipse>
    <ellipse cx="62" cy="42" rx="15" ry="14" fill="url(#petal-grad)"></ellipse>
    <ellipse cx="52" cy="58" rx="14" ry="13" fill="url(#petal-grad)"></ellipse>
    <ellipse cx="36" cy="52" rx="13" ry="12" fill="url(#petal-grad)" opacity="0.95"></ellipse>
    <ellipse cx="68" cy="54" rx="13" ry="12" fill="url(#petal-grad)" opacity="0.95"></ellipse>
    <ellipse cx="54" cy="34" rx="12" ry="11" fill="url(#petal-grad)" opacity="0.9"></ellipse>
    <circle cx="52" cy="48" r="9" fill="url(#tsubaki-core)"></circle>
    <circle cx="48" cy="45" r="1.4" fill="#9a7b2d" opacity="0.85"></circle>
    <circle cx="56" cy="45" r="1.4" fill="#9a7b2d" opacity="0.85"></circle>
    <circle cx="52" cy="51" r="1.4" fill="#9a7b2d" opacity="0.85"></circle>
    <circle cx="50" cy="48" r="1" fill="#9a7b2d" opacity="0.6"></circle>
    <circle cx="54" cy="48" r="1" fill="#9a7b2d" opacity="0.6"></circle>
    <path
      d="M74 68 C88 54 86 32 74 24 C62 34 66 56 74 68"
      fill="#2e3d4a"></path>
    <path
      d="M76 26 C70 38 72 54 78 64"
      fill="none"
      stroke="#fffaf2"
      stroke-width="1.4"
      opacity="0.65"
      stroke-linecap="round"></path>
    <path
      d="M80 32 C74 42 76 52 82 58"
      fill="none"
      stroke="#fffaf2"
      stroke-width="0.9"
      opacity="0.45"
      stroke-linecap="round"></path>
  </svg>

  <div class="site-title-banner__content">
    <span class="site-title-banner__ornament" aria-hidden="true">◆</span>
    <div class="site-title site-title--banner">
      <a href={href} data-ui="site.name">{ui.ja["site.name"]}</a>
    </div>
    <span class="site-title-banner__ornament" aria-hidden="true">◆</span>
  </div>
</div>
